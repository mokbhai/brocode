{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BroCode (Alpha)",
  "version": "0.0.42",
  "identifier": "com.t3tools.brocode",
  "build": {
    "beforeDevCommand": {
      "script": "node scripts/run-web-with-tauri-entry.js run dev -- --host 127.0.0.1 --port 5733",
      "cwd": "..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "node scripts/build-release-assets.js",
      "cwd": ".."
    },
    "devUrl": "http://127.0.0.1:5733",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "BroCode Tauri (POC)",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": {
      "../../server/dist": "brocode-runtime/apps/server/dist"
    },
    "targets": "all"
  }
}
