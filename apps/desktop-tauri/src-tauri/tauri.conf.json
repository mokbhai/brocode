{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DP Code Tauri (POC)",
  "version": "0.0.42",
  "identifier": "com.t3tools.dpcode.tauri.dev",
  "build": {
    "beforeDevCommand": {
      "script": "node scripts/run-web-with-tauri-entry.js run dev -- --host 127.0.0.1 --port 5733",
      "cwd": "..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "node scripts/run-web-with-tauri-entry.js run build",
      "cwd": ".."
    },
    "devUrl": "http://127.0.0.1:5733",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DP Code Tauri (POC)",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["../../desktop/resources/icon.png"],
    "targets": "all"
  }
}
